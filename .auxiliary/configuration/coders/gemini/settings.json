{
  "ui": {
    "showLineNumbers": true
  },
  "tools": {
    "autoAccept": true,
    "core": [
      "mcp__agentmux__list",
      "mcp__agentmux__look",
      "mcp__agentmux__send",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__nb__help",
      "mcp__nb__nb",
      "edit",
      "glob",
      "google_web_search",
      "list_directory",
      "read_file",
      "replace",
      "run_shell_command",
      "save_memory",
      "search_file_content",
      "web_fetch",
      "write_file",
      "write_todos"
    ]
  },
  "general": {
    "checkpointing": {
      "enabled": true
    }
  },
  "mcpServers": {
    "agentmux": {
      "command": "agentmux",
      "args": [
        "host", "mcp",
        "--bundle", "ai-experiments"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [ "-y", "@upstash/context7-mcp" ]
    },
    "nb": {
      "command": "nb-mcp",
      "args": [
        "--notebook", "ai-experiments",
        "--no-commit-signing"
      ]
    }
  }
}
