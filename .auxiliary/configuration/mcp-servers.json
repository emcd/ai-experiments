{
  "mcpServers": {
    "agentmux": {
      "command": "agentmux",
      "args": [
        "host", "mcp",
        "--bundle", "ai-experiments"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [ "-y", "@upstash/context7-mcp" ]
    },
    "nb": {
      "command": "nb-mcp",
      "args": [
        "--notebook", "ai-experiments",
        "--no-commit-signing"
      ]
    }
  }
}
